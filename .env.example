# Example .env for ollama_system
# For local Ollama server (recommended for development):
OLLAMA_HOST=http://localhost:11434

# For Ollama Cloud (uncomment and set your API key):
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=your_api_key_here

# Optional: change model cache TTL (seconds)
# MODEL_CACHE_TTL=3600
