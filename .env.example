# ===== Multi-Provider Configuration =====
# Define all providers as a JSON array in PROVIDERS env var
# Example with multiple providers:
PROVIDERS='[
  {
    "name": "ollama",
    "type": "ollama",
    "base_url": "https://ollama.com",
    "api_key": "your-ollama-key",
    "models": ["model1", "model2"],
    "enabled": true
  },
  {
    "name": "openai_claud",
    "type": "openai",
    "base_url": "https://api.claud.io/v1",
    "api_key": "your-claud-key",
    "models": ["DeepSeek V3", "Claude 3.5"],
    "enabled": true
  },
  {
    "name": "openai_together",
    "type": "openai",
    "base_url": "https://api.together.xyz/v1",
    "api_key": "your-together-key",
    "models": ["meta-llama/Llama-3-70b"],
    "enabled": true
  }
]'

# ===== OR use individual provider env vars =====
# Ollama configuration (fallback if PROVIDERS not set)
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODELS=model1,model2,model3

# OpenAI-compatible configuration (fallback if PROVIDERS not set)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODELS=gpt-4,gpt-3.5-turbo

# ===== Model Cache Configuration =====
MODEL_CACHE_TTL=3600
MODEL_VERIFY_ACCESS=true

# ===== Logging =====
LOG_LEVEL=INFO
